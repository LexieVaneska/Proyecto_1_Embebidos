# Artefactos de compilacion de Rust
detector_ojos/target/

# Modelos pesados usados por Facemark u otros detectores
detector_ojos/models/*.yaml
detector_ojos/models/*.yml
detector_ojos/models/*.bin
detector_ojos/models/*.dat

# Videos de prueba y salidas generadas localmente
detector_ojos/videos/*.mp4
detector_ojos/videos/*.avi
detector_ojos/videos/*.mov
detector_ojos/videos/*.mkv
detector_ojos/videos_salida/*.mp4
detector_ojos/videos_salida/*.avi
detector_ojos/videos_salida/*.mov
detector_ojos/videos_salida/*.mkv

# Mantener las carpetas versionadas aunque esten vacias
!detector_ojos/videos/.gitkeep
!detector_ojos/videos_salida/.gitkeep
